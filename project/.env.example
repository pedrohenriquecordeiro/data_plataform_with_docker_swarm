# .env.example — Template for all non-secret environment variables
# Copy this file to .env and fill in the values before deploying.
# IMPORTANT: Restrict permissions on the .env file: chmod 600 .env
# Secrets (passwords, keys) must NOT go here — use Docker Swarm secrets instead.

# ═════════════════════════════════════════════════════════════════════════════
# MinIO Configuration
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# MinIO Credentials (plaintext values — deploy scripts create Swarm secrets from these)
# ─────────────────────────────────────────────────────────────────────────────

# Root username for MinIO (minimum 3 characters).
MINIO_WWW_USERNAME=minioadmin

# Root password for MinIO (minimum 8 characters).
MINIO_WWW_PASSWORD=changeme_minio_password

# ─────────────────────────────────────────────────────────────────────────────
# MinIO Client Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Local endpoint to reach the MinIO API (used by mc client)
MINIO_HOSTNAME=http://127.0.0.1:9000

# Alias name for the MinIO Client (mc) configuration
MINIO_CLIENT_NAME=local-minio

# Name of the default bucket to create for Airflow data
BUCKET_NAME=init-bucket

# ─────────────────────────────────────────────────────────────────────────────
# MinIO Ports
# ─────────────────────────────────────────────────────────────────────────────

# MinIO S3 API port (exposed on the host)
MINIO_PORT_API=9000

# MinIO web console port (exposed on the host)
MINIO_PORT_CONSOLE=9001

# ═════════════════════════════════════════════════════════════════════════════
# Airflow Configuration
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Airflow Image
# ─────────────────────────────────────────────────────────────────────────────

# Full registry path and tag for the custom Airflow image built from airflow/Dockerfile.
# TODO(user): push image to registry and update this value
AIRFLOW_IMAGE=airflow:2.10.5

# ─────────────────────────────────────────────────────────────────────────────
# Airflow Admin Credentials (for initial setup — will become Swarm secrets)
# ─────────────────────────────────────────────────────────────────────────────

# Temporary admin credentials used by deploy_airflow.sh to create Swarm secrets.
# Change these before first deploy and do NOT commit this file with real values.
AIRFLOW_WWW_USERNAME=admin
AIRFLOW_WWW_PASSWORD=changeme_admin_password

# ─────────────────────────────────────────────────────────────────────────────
# Airflow Secrets (plaintext values — deploy scripts create Swarm secrets from these)
# ─────────────────────────────────────────────────────────────────────────────

# Fernet key for encrypting sensitive data in Airflow's metadata database.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=changeme_generate_fernet_key

# Flask secret key for Airflow webserver session management.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_SECRET_KEY=changeme_generate_secret_key

# Password for the PostgreSQL 'airflow' database user.
AIRFLOW_POSTGRES_PASSWORD=changeme_db_password

# ─────────────────────────────────────────────────────────────────────────────
# Airflow Performance Tuning
# ─────────────────────────────────────────────────────────────────────────────

# Maximum number of task instances that can run concurrently across all DAGs.
AIRFLOW_PARALLELISM=1

# Number of concurrent tasks a single Celery worker can execute.
# Recommended: set to the number of available CPU cores on the worker node.
AIRFLOW_WORKER_CONCURRENCY=1

# ─────────────────────────────────────────────────────────────────────────────
# Airflow Ports
# ─────────────────────────────────────────────────────────────────────────────

# Airflow webserver UI port (exposed on the host)
AIRFLOW_WEBSERVER_PORT=8080
